# Copy this file to .env and fill in your values.
#   cp .env.example .env

# API key for the configured LLM provider (see config/settings.yaml -> llm).
# Use a model that supports native json_schema structured output.
LLM_API_KEY=


# Password for the Salt API user (default username "agent" in settings.yaml).
SALT_API_PASSWORD=


# Set LANGSMITH_TRACING=true and drop in your key to enable tracing.
# Nothing else needs wiring -- LangChain reads these automatically.
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=uyuni-ai-agent
LANGSMITH_ENDPOINT=https://api.smith.langchain.com


# Overrides logging.level in settings.yaml if set (DEBUG/INFO/WARNING/ERROR).
# LOG_LEVEL=INFO
